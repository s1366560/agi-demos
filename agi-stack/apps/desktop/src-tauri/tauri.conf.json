{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agistack Desktop",
  "version": "0.1.0",
  "identifier": "ai.agistack.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Agistack Desktop",
        "width": 920,
        "height": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
