{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agi-stack Desktop",
  "version": "0.1.0",
  "identifier": "ai.agistack.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "create": false,
        "url": "index.html",
        "title": "agi-stack Desktop",
        "width": 1728,
        "height": 1024,
        "minWidth": 1080,
        "minHeight": 720,
        "center": true,
        "focus": true,
        "titleBarStyle": "Visible",
        "hiddenTitle": false,
        "visible": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:* http://localhost:* ws://localhost:*",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
