{
  "include": [
    "src",
    "sdk",
    "scripts"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/.mypy_cache",
    "**/.git",
    ".venv",
    "web",
    "design-prototype",
    "notebooks",
    "logs",
    "alembic",
    "src/tests",
    "src/alembic",
    "src/memstack_agent"
  ],
  "ignore": [
    "scripts/convert_md_to_docx.py",
    "scripts/generate_event_types.py",
    "scripts/memstack-cli.py",
    "sdk/python/memstack/async_client.py",
    "sdk/python/memstack/client.py",
    "sdk/python/memstack/exceptions.py",
    "src/application/services/channels/hitl_responder.py",
    "src/domain/model/agent/execution/agent_execution_event.py",
    "src/domain/model/agent/workflow_pattern.py",
    "src/domain/ports/tool_port.py",
    "src/infrastructure/adapters/primary/web/routers/agent/hitl.py",
    "src/infrastructure/adapters/primary/web/routers/sandbox/utils.py",
    "src/infrastructure/adapters/primary/web/startup/container.py",
    "src/infrastructure/adapters/primary/web/websocket/handlers/chat_handler.py",
    "src/infrastructure/adapters/primary/web/websocket/handlers/hitl_handler.py",
    "src/infrastructure/adapters/primary/web/websocket/handlers/status_handler.py",
    "src/infrastructure/adapters/secondary/common/base_repository.py",
    "src/infrastructure/adapters/secondary/common/health_check.py",
    "src/infrastructure/adapters/secondary/common/transaction_manager.py",
    "src/infrastructure/adapters/secondary/external/volcengine/asr_streaming_client.py",
    "src/infrastructure/adapters/secondary/external/volcengine/tts_streaming_client.py",
    "src/infrastructure/adapters/secondary/persistence/sql_hitl_request_repository.py",
    "src/infrastructure/adapters/secondary/persistence/sql_skill_repository.py",
    "src/infrastructure/adapters/secondary/persistence/sql_tool_execution_record_repository.py",
    "src/infrastructure/adapters/secondary/sandbox/constants.py",
    "src/infrastructure/adapters/secondary/sandbox/reconciler.py",
    "src/infrastructure/agent/actor/hitl_router_actor.py",
    "src/infrastructure/agent/actor/project_agent_actor.py",
    "src/infrastructure/agent/canvas/a2ui_builder.py",
    "src/infrastructure/agent/context/window_manager.py",
    "src/infrastructure/agent/core/plugin_tool_adapter.py",
    "src/infrastructure/agent/core/sandbox_tool_executor.py",
    "src/infrastructure/agent/hitl/local_resume_consumer.py",
    "src/infrastructure/agent/hitl/recovery_service.py",
    "src/infrastructure/agent/hitl/utils.py",
    "src/infrastructure/agent/llm/__init__.py",
    "src/infrastructure/agent/mcp/registry.py",
    "src/infrastructure/agent/pool/backends/container_backend.py",
    "src/infrastructure/agent/pool/container/server.py",
    "src/infrastructure/agent/pool/ha/failure_recovery.py",
    "src/infrastructure/agent/pool/integration/session_adapter.py",
    "src/infrastructure/agent/pool/orchestrator.py",
    "src/infrastructure/agent/processor/hitl_tool_handler.py",
    "src/infrastructure/agent/tools/env_var_tools.py",
    "src/infrastructure/agent/tools/sandbox_tool_wrapper.py",
    "src/infrastructure/agent/workspace/workspace_inbox_loop.py",
    "src/infrastructure/graph/community/community_updater.py",
    "src/infrastructure/graph/distributed_transaction_coordinator.py",
    "src/infrastructure/graph/embedding/embedding_service.py",
    "src/infrastructure/graph/extraction/entity_extractor.py",
    "src/infrastructure/graph/extraction/prompts.py",
    "src/infrastructure/graph/extraction/reflexion.py",
    "src/infrastructure/graph/extraction/relationship_extractor.py",
    "src/infrastructure/graph/neo4j_client.py",
    "src/infrastructure/graph/schemas.py",
    "src/infrastructure/llm/registry.py",
    "src/infrastructure/llm/validation.py",
    "src/infrastructure/mcp/clients/http_client.py",
    "src/infrastructure/mcp/sandbox_tool_adapter.py",
    "src/infrastructure/memory/query_expansion.py",
    "src/infrastructure/telemetry/config.py",
    "src/infrastructure/telemetry/tracing.py"
  ],
  "pythonVersion": "3.12",
  "pythonPlatform": "All",
  "venvPath": ".",
  "venv": ".venv",
  "extraPaths": [
    "."
  ],
  "typeCheckingMode": "strict",
  "useLibraryCodeForTypes": true,
  "analyzeUnannotatedFunctions": true,
  "strictListInference": true,
  "strictDictionaryInference": true,
  "strictSetInference": true,
  "strictParameterNoneValue": true,
  "deprecateTypingAliases": true,
  "disableBytesTypePromotions": true,
  "reportMissingTypeStubs": "warning",
  "reportIncompatibleMethodOverride": "warning",
  "reportIncompatibleVariableOverride": "warning",
  "reportImportCycles": "warning",
  "reportPrivateUsage": "warning",
  "reportTypeCommentUsage": "error",
  "reportUntypedFunctionDecorator": "error",
  "reportUntypedClassDecorator": "error",
  "reportUntypedBaseClass": "error",
  "reportUntypedNamedTuple": "error",
  "reportConstantRedefinition": "error",
  "reportDeprecated": "warning",
  "reportImplicitStringConcatenation": "warning",
  "reportUnnecessaryIsInstance": "warning",
  "reportUnnecessaryCast": "error",
  "reportUnnecessaryComparison": "error",
  "reportUnnecessaryContains": "error",
  "reportCallInDefaultInitializer": false,
  "reportMissingSuperCall": "warning",
  "reportUninitializedInstanceVariable": "error",
  "reportUnknownParameterType": "error",
  "reportUnknownArgumentType": "warning",
  "reportUnknownLambdaType": "warning",
  "reportUnknownVariableType": "warning",
  "reportUnknownMemberType": "warning",
  "reportMissingParameterType": "error",
  "reportMissingTypeArgument": "error",
  "reportInvalidTypeVarUse": "error",
  "reportUnusedCallResult": "warning",
  "reportUnusedExpression": "error",
  "reportUnnecessaryTypeIgnoreComment": "warning",
  "reportMatchNotExhaustive": "warning",
  "reportImplicitOverride": "warning",
  "reportPropertyTypeMismatch": "warning",
  "reportOptionalMemberAccess": "warning",
  "reportOptionalSubscript": "warning",
  "reportOptionalCall": "warning"
}
