{
  "id": "feishu-channel-plugin",
  "kind": "channel",
  "name": "Feishu Channel Plugin",
  "description": "Feishu (Lark) IM platform integration providing messaging, document, wiki, drive, bitable, and card building capabilities via WebSocket and Webhook modes.",
  "version": "1.0.0",
  "channels": ["feishu"],
  "providers": [],
  "skills": [],
  "contracts": {
    "channels": ["feishu"]
  },
  "activation": {
    "onStartup": false,
    "onChannels": ["feishu"]
  },
  "toolMetadata": {},
  "hookMetadata": {},
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "app_id": {
        "type": "string",
        "minLength": 1
      },
      "app_secret": {
        "type": "string",
        "minLength": 1
      },
      "encrypt_key": {
        "type": "string"
      },
      "verification_token": {
        "type": "string"
      },
      "domain": {
        "type": "string",
        "default": "feishu"
      },
      "connection_mode": {
        "type": "string",
        "enum": ["websocket", "webhook"],
        "default": "websocket"
      },
      "webhook_url": {
        "type": "string"
      },
      "webhook_port": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      },
      "webhook_path": {
        "type": "string"
      }
    },
    "required": ["app_id", "app_secret"]
  },
  "uiHints": {
    "app_secret": {
      "sensitive": true
    },
    "encrypt_key": {
      "sensitive": true,
      "advanced": true
    },
    "verification_token": {
      "sensitive": true,
      "advanced": true
    },
    "webhook_port": {
      "advanced": true
    },
    "webhook_path": {
      "advanced": true
    }
  },
  "channelEnvVars": {
    "feishu": ["FEISHU_APP_ID", "FEISHU_APP_SECRET"]
  }
}
